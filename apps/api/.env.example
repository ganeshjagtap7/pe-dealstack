# Supabase Configuration
# Get these from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# Server Configuration
PORT=3001
NODE_ENV=development

# ─── LLM provider keys ──────────────────────────────────────────────
# Tier-1 callsites (deal chat, memos, extraction reasoning, analysis)
# now route to Anthropic DIRECT via @langchain/anthropic when
# ANTHROPIC_API_KEY is present. On error or when the key is missing
# they fall back to OpenAI direct (gpt-4o) via OPENAI_API_KEY.
#
# Routing cascade for tier-1:
#   1. ANTHROPIC_API_KEY set → Anthropic direct (claude-sonnet-4-5)   ← preferred
#   2. else OPENAI_API_KEY set → OpenAI direct (gpt-4o)
#   3. else OPENROUTER_API_KEY set → OpenRouter (legacy, anthropic/claude-sonnet-4.5)
#
# Tiers 2-4 (classification, fast tasks) still route via OpenAI direct
# or OpenRouter if OPENROUTER_API_KEY is set.

# Anthropic Configuration (preferred tier-1 provider)
# Get your API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# OpenAI Configuration (tier-1 fallback + default tier-2/3/4 provider)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# OpenRouter Configuration (LEGACY tier-1 path; still usable for tiers 2-4)
# When set, OPENAI_API_KEY-using callsites pivot to openrouter.ai and the
# tier-2/3/4 prefixed model IDs ("openai/gpt-4.1", ...) take effect.
# OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Gemini API Configuration (for RAG)
# Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Tavily search API keys — power the web_search tool in dealChat agent.
# Primary key is used first; fallback rolls in on HTTP 429/432 (rate limit
# or credits exhausted). Both are optional in dev — tool returns a polite
# "not configured" message if TAVILY_API_KEY is unset. Get keys at
# https://app.tavily.com (free dev tier ships with 1k credits/month).
TAVILY_API_KEY=
TAVILY_API_KEY_FALLBACK=

# ─── LangSmith tracing (optional, for debugging LangChain runs) ─────
# When all four are set, every LangChain / LangGraph call (deal-chat
# agent, memo pipeline, financial agent, email drafter, etc.) auto-
# traces to https://smith.langchain.com under the named project. Raw
# Anthropic / OpenAI SDK calls are wrapped via langsmith/wrappers
# (services/anthropic.ts, financialAgent/nodes/verifyNode.ts) so they
# trace too. Leave unset to disable tracing entirely.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_<paste-from-langsmith-dashboard>
LANGSMITH_PROJECT=dealstack

# LangExtract Deep Extraction (optional)
# Python microservice for long document extraction (>50k chars)
# Run: cd apps/extractor && python server.py
EXTRACTOR_URL=http://localhost:5050

# Data Encryption Key (optional)
# AES-256-GCM encryption for sensitive deal fields at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this key, data is stored in plaintext (graceful degradation for dev).
DATA_ENCRYPTION_KEY=

# Azure Document Intelligence (optional — Layer 1 for financial table extraction)
# When set, Azure prebuilt-layout runs first on PDFs for best table quality.
# Falls back to GPT-4o text / Vision if not configured.
# Get endpoint + key: https://portal.azure.com → Azure AI services → Document Intelligence
AZURE_DOC_INTEL_ENDPOINT=
AZURE_DOC_INTEL_KEY=

# App URL (required in production — used for invitation/share links in emails)
APP_URL=https://your-production-domain.com

# Resend Email Service (required for invitations + document sharing)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# CORS — Additional allowed origins (comma-separated, optional)
# Default allowlist already includes lmmos.ai (+ www) and Vercel preview
# domains. Use this only if you need to add a one-off origin.
ALLOWED_ORIGINS=

# Sentry Error Tracking (optional)
# Get your DSN from https://sentry.io/settings/projects/
SENTRY_DSN=

# Integrations platform (Phase 0)
OAUTH_STATE_SECRET=                # 32+ chars, used for HMAC of OAuth state JWT
CRON_SECRET=                       # shared secret between Vercel cron and the API

# Granola (Phase 1) — base URL only; users paste their own grn_ keys via UI.
GRANOLA_API_BASE=https://public-api.granola.ai

# Gmail (Phase 2) + Google Calendar (Phase 3) — shared Google OAuth client credentials.
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs (add both):
#   ${APP_URL}/api/integrations/oauth/gmail/callback
#   ${APP_URL}/api/integrations/oauth/google_calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# AI Usage Tracking
# ============================================================
# Per-unit prices for non-LLM providers (used by the cost ledger).
# Tune to match your Apify / Azure dashboard rates.
APIFY_PRICE_PER_SEARCH_USD=0.005
APIFY_PRICE_PER_LINKEDIN_PROFILE_USD=0.02
AZURE_DOC_PRICE_PER_PAGE_USD=0.0015

# Per-1K-character price for Gemini text-embedding-004 (used by RAG ingest
# + retrieval). Verify against Google's current rate; a generous free tier
# exists at low volume, but cost ≠ 0 above quota.
GEMINI_EMBED_PRICE_PER_1K_CHARS_USD=0.000025
