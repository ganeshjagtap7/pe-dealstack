# Supabase Configuration
# Get these from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# Server Configuration
PORT=3001
NODE_ENV=development

# OpenAI Configuration (for AI features)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Gemini API Configuration (for RAG)
# Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# LangExtract Deep Extraction (optional)
# Python microservice for long document extraction (>50k chars)
# Run: cd apps/extractor && python server.py
EXTRACTOR_URL=http://localhost:5050

# Data Encryption Key (optional)
# AES-256-GCM encryption for sensitive deal fields at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this key, data is stored in plaintext (graceful degradation for dev).
DATA_ENCRYPTION_KEY=

# Azure Document Intelligence (optional — Layer 1 for financial table extraction)
# When set, Azure prebuilt-layout runs first on PDFs for best table quality.
# Falls back to GPT-4o text / Vision if not configured.
# Get endpoint + key: https://portal.azure.com → Azure AI services → Document Intelligence
AZURE_DOC_INTEL_ENDPOINT=
AZURE_DOC_INTEL_KEY=

# App URL (required in production — used for invitation/share links in emails)
APP_URL=https://your-production-domain.com

# Resend Email Service (required for invitations + document sharing)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# CORS — Additional allowed origins (comma-separated, optional)
# Your production frontend domain(s). Default: pe-os.onrender.com + pe-dealstack.vercel.app
ALLOWED_ORIGINS=

# Sentry Error Tracking (optional)
# Get your DSN from https://sentry.io/settings/projects/
SENTRY_DSN=

# Integrations platform (Phase 0)
OAUTH_STATE_SECRET=                # 32+ chars, used for HMAC of OAuth state JWT
CRON_SECRET=                       # shared secret between Vercel cron and the API

# Provider credentials (filled in per-phase as we wire them)
# GRANOLA_CLIENT_ID=
# GRANOLA_CLIENT_SECRET=
# GRANOLA_WEBHOOK_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
