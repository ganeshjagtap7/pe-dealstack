    DEAL ||--o{ DEAL_TEAM_MEMBER : "assigned"
    DEAL ||--o{ DOCUMENT_CHUNK : "indexed"
    DEAL ||--o{ MEMO : "reports"
    DEAL ||--o{ NARRATIVE_INSIGHT_CACHE : "caches"

    USER ||--o{ ACTIVITY : "performs"
    USER ||--o{ CHAT_MESSAGE : "sends"
    USER ||--o{ NOTIFICATION : "receives"
    USER ||--o{ DEAL_TEAM_MEMBER : "member of"
    USER ||--o{ MEMO : "creates"

    DOCUMENT ||--o{ DOCUMENT_CHUNK : "chunked into"
    DOCUMENT ||--o{ FINANCIAL_STATEMENT : "extracted from"
    FOLDER ||--o{ DOCUMENT : "contains"
