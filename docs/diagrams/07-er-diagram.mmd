erDiagram
    ORGANIZATION {
        uuid id PK
        string name
        string slug
        string logo
        string industry
        string plan
        int maxUsers
        boolean isActive
        timestamp createdAt
    }

    USER {
        uuid id PK
        string authId UK
        string email UK
        string name
        string role "ADMIN MEMBER VIEWER OPS"
        uuid organizationId FK
        jsonb preferences
        timestamp createdAt
    }

    DEAL {
        uuid id PK
        uuid companyId FK
        uuid organizationId FK
        string name
        string stage "7 pipeline stages"
        string status "ACTIVE CLOSED_WON CLOSED_LOST PASSED"
        string priority "LOW MEDIUM HIGH URGENT"
        float dealSize
        float revenue
        float ebitda
        float irrProjected
        timestamp createdAt
    }

    COMPANY {
        uuid id PK
        uuid organizationId FK
        string name
        string industry
        string website
        string description
        timestamp createdAt
    }

    CONTACT {
        uuid id PK
        uuid organizationId FK
        string firstName
        string lastName
        string email
        string title
        string company
        string type "BANKER ADVISOR EXECUTIVE LP LEGAL"
        timestamp createdAt
    }

    CONTACT_INTERACTION {
        uuid id PK
        uuid contactId FK
        string type "NOTE MEETING CALL EMAIL"
        date date
        string description
    }

    CONTACT_DEAL {
        uuid contactId FK
        uuid dealId FK
        string role "BANKER ADVISOR BOARD MGMT"
    }

    DOCUMENT {
        uuid id PK
        uuid dealId FK
        uuid folderId FK
        string name
        string type "CIM TEASER FINANCIAL LEGAL TAX OTHER"
        string fileUrl
        int fileSize
        jsonb aiAnalysis
        text extractedText
        string_arr tags
        uuid uploadedBy FK
        timestamp createdAt
    }

    FOLDER {
        uuid id PK
        uuid dealId FK
        uuid parentId FK
        string name
        boolean isRestricted
        int sortOrder
        timestamp createdAt
    }

    FOLDER_INSIGHT {
        uuid id PK
        uuid folderId FK
        text summary
        int completionPercent
        string_arr redFlags
        string_arr missingDocuments
        timestamp createdAt
    }

    FINANCIAL_STATEMENT {
        uuid id PK
        uuid dealId FK
        uuid documentId FK
        string statementType "INCOME BALANCE CASH_FLOW"
        string period
        jsonb lineItems
        string extractionSource "gpt4o azure vision manual"
        float extractionConfidence
        boolean isActive
        string mergeStatus "auto needs_review user_resolved"
        timestamp createdAt
    }

    DOCUMENT_CHUNK {
        uuid id PK
        uuid documentId FK
        uuid dealId FK
        text content
        jsonb embedding
        int chunkIndex
    }

    MEMO {
        uuid id PK
        uuid dealId FK
        uuid organizationId FK
        string title
        string type "IC_MEMO TEASER SUMMARY"
        string status "DRAFT REVIEW FINAL ARCHIVED"
        uuid createdBy FK
        timestamp createdAt
    }

    MEMO_SECTION {
        uuid id PK
        uuid memoId FK
        string type "12 section types"
        text content
        boolean aiGenerated
        int sortOrder
    }

    MEMO_TEMPLATE {
        uuid id PK
        uuid organizationId FK
        string name
        string type
        jsonb sections
        timestamp createdAt
    }

    ACTIVITY {
        uuid id PK
        uuid dealId FK
        uuid userId FK
        string type "DOCUMENT_UPLOADED STAGE_CHANGED etc"
        string title
        text description
        timestamp createdAt
    }

    CHAT_MESSAGE {
        uuid id PK
        uuid dealId FK
        uuid userId FK
        string role "user assistant system"
        text content
        jsonb metadata
        timestamp createdAt
    }

    NOTIFICATION {
        uuid id PK
        uuid userId FK
        uuid organizationId FK
        string type
        string title
        text message
        boolean isRead
        timestamp createdAt
    }

    INVITATION {
        uuid id PK
        uuid organizationId FK
        string email
        string role
        string token UK
        string status "PENDING ACCEPTED EXPIRED REVOKED"
        uuid invitedBy FK
        timestamp createdAt
    }

    DEAL_TEAM_MEMBER {
        uuid dealId FK
        uuid userId FK
        string accessLevel "view edit admin"
        uuid addedBy FK
        timestamp createdAt
    }

    TASK {
        uuid id PK
        uuid dealId FK
        uuid organizationId FK
        uuid assignedTo FK
        string title
        text description
        string status
        date dueDate
        timestamp createdAt
    }

    AUDIT_LOG {
        uuid id PK
        uuid userId FK
        uuid organizationId FK
        string action
        string resourceType
        uuid resourceId
        string severity "INFO WARNING ERROR CRITICAL"
        string ipAddress
        jsonb metadata
        timestamp createdAt
    }

    AGENT_MEMORY_INDUSTRY {
        uuid id PK
        uuid organizationId FK
        string industry
        string metric
        float typicalLow
        float typicalMid
        float typicalHigh
        int sampleSize
    }

    AGENT_MEMORY_EXTRACTION {
        uuid id PK
        uuid organizationId FK
        string documentPattern
        string fileType
        string bestExtractionSource
        float avgConfidence
    }

    NARRATIVE_INSIGHT_CACHE {
        uuid id PK
        uuid dealId FK
        uuid organizationId FK
        string analysisHash
        jsonb insights
        timestamp createdAt
    }

