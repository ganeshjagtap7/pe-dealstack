flowchart TB
    subgraph LLMLayer["Unified LLM Layer — services/llm.ts"]
        direction LR
        ChatModel["getChatModel()
        GPT-4o — main reasoning"]
        FastModel["getFastModel()
        GPT-4o-mini — verify, classify"]
        ExtractModel["getExtractionModel()
        GPT-4o — structured JSON"]
        GeminiAlt["Gemini fallback
        LLM_CHAT_PROVIDER env"]
    end

    subgraph FinancialAgent["Financial Agent — LangGraph (6 nodes)"]
        direction TB
        FA_Entry["runFinancialAgent()
        services/agents/financialAgent/index.ts"]
        FA_Extract["extract
        3-layer fallback:
        Azure DI → pdf-parse+GPT-4o → Vision"]
        FA_Verify["verify
        Two-pass GPT-4o-mini
        catches scale + transposition errors"]
        FA_CrossVerify["cross_verify
        Cross-statement consistency
        e.g. Net Income → Cash Flow"]
        FA_Validate["validate
        Range and accounting checks"]
        FA_SelfCorrect["self_correct
        Targeted re-extraction
        max 3 retries"]
        FA_Store["store
        DB persistence + merge conflicts"]
        FA_Entry --> FA_Extract --> FA_Verify --> FA_CrossVerify --> FA_Validate
        FA_Validate -->|fail| FA_SelfCorrect -->|retry| FA_Validate
        FA_Validate -->|pass| FA_Store
    end

    subgraph DealChatAgent["Deal Chat Agent — ReAct (14 tools)"]
        direction TB
        DC_Entry["runDealChatAgent()
        services/agents/dealChatAgent/index.ts"]
        DC_Tools["getDealChatTools(dealId, orgId)
        closure-bound LangChain tools"]
        DC_Read["READ tools
        search_documents
        get_deal_financials
        compare_deals
        get_deal_activity
        get_analysis_summary
        list_documents"]
        DC_Write["WRITE tools
        update_deal_field
        change_deal_stage
        add_note"]
        DC_Trigger["TRIGGER tools
        trigger_financial_extraction
        generate_meeting_prep
        draft_email"]
        DC_Nav["UI tools
        scroll_to_section
        suggest_action"]
        DC_Entry --> DC_Tools --> DC_Read & DC_Write & DC_Trigger & DC_Nav
    end

    subgraph FirmResearch["Firm Research Agent — LangGraph (6 nodes)"]
        direction TB
        FR_Entry["runFirmResearch()
        services/agents/firmResearchAgent/index.ts"]
        FR_Scrape["scrape
        Firm website + LinkedIn"]
        FR_SearchFirm["search_firm
        Apify Google Search"]
        FR_SearchPerson["search_person
        Founder/partner background"]
        FR_Synth["synthesize
        Strategy + sectors + check size"]
        FR_Verify["verify
        Confidence scoring"]
        FR_Save["save
        Org.settings.firmProfile"]
        FR_Deep["deep_research (Phase 2)
        background, 60-120s
        GPT-4o query gen + threads"]
        FR_Entry --> FR_Scrape --> FR_SearchFirm --> FR_SearchPerson --> FR_Synth --> FR_Verify --> FR_Save
        FR_Save -.->|"async background"| FR_Deep
    end

    subgraph MemoAgent["Memo Agent — Pipeline + Tools"]
        direction TB
        MA_Entry["services/agents/memoAgent/index.ts"]
        MA_Pipeline["pipeline.ts
        section-by-section generation"]
        MA_Context["context.ts
        deal data + financials + docs"]
        MA_Tools["tools.ts
        section-specific helpers"]
        MA_Prompts["prompts.ts
        12 section types"]
        MA_Entry --> MA_Pipeline --> MA_Context & MA_Tools & MA_Prompts
    end

    subgraph ContactEnrich["Contact Enrichment — 4-node graph"]
        direction TB
        CE_Entry["services/agents/contactEnrichment/index.ts"]
        CE_Research["research
        LLM inference"]
        CE_Validate["validate
        input-sparsity caps:
        name only → max 30%
        name+email → max 50%"]
        CE_Save["save
        store enrichment"]
        CE_Review["review
        flag low-confidence"]
        CE_Entry --> CE_Research --> CE_Validate
        CE_Validate -->|high| CE_Save
        CE_Validate -->|low| CE_Review
    end

    subgraph MeetingPrep["Meeting Prep — Parallel Fetcher"]
        direction TB
        MP_Entry["services/agents/meetingPrep/index.ts"]
        MP_Fetch["Parallel fetch — 5 sources"]
        MP_S1["Deal info"]
        MP_S2["Financial statements"]
        MP_S3["Activity timeline"]
        MP_S4["Contacts"]
        MP_S5["Company research"]
        MP_Brief["Generate brief
        Talking points, questions,
        risks, agenda"]
        MP_Entry --> MP_Fetch --> MP_S1 & MP_S2 & MP_S3 & MP_S4 & MP_S5
        MP_S1 & MP_S2 & MP_S3 & MP_S4 & MP_S5 --> MP_Brief
    end

    subgraph SignalMonitor["Signal Monitor — 3-node graph"]
        direction TB
        SM_Entry["services/agents/signalMonitor/index.ts"]
        SM_Fetch["fetchPortfolio
        all active deals"]
        SM_Analyze["analyzeSignals
        8 signal types"]
        SM_Route["routeSignals
        critical / warning / info"]
        SM_Entry --> SM_Fetch --> SM_Analyze --> SM_Route
    end

    subgraph EmailDrafter["Email Drafter — 4-node graph"]
        direction TB
        ED_Entry["services/agents/emailDrafter/index.ts"]
        ED_Write["writeDraft
        7 templates"]
        ED_Tone["toneCheck
        5 tones"]
        ED_Compliance["complianceCheck
        PE compliance rules"]
        ED_Final["finalize
        ready_for_review or
        compliance_issues"]
        ED_Entry --> ED_Write --> ED_Tone --> ED_Compliance --> ED_Final
    end

    subgraph APIEndpoints["API Endpoints"]
        direction LR
        EP1["POST /api/ai/enrich-contact"]
        EP2["POST /api/ai/meeting-prep"]
        EP3["POST /api/ai/draft-email"]
        EP4["POST /api/ai/scan-signals"]
        EP5["POST /api/deals/:id/chat
        (deals-chat-ai.ts)"]
        EP6["POST /api/ai/portfolio/chat"]
        EP7["POST /api/onboarding/enrich-firm"]
        EP8["POST /api/financials/extract
        (financials-extraction.ts)"]
        EP9["POST /api/memos/:id/sections/:id/generate"]
    end

