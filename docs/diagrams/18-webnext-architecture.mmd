    style AppGroup fill:#10b981,color:#fff,stroke:#059669
    style Components fill:#3b82f6,color:#fff,stroke:#2563eb
    style LibLayer fill:#8b5cf6,color:#fff,stroke:#7c3aed
    style Providers fill:#14b8a6,color:#fff,stroke:#0d9488
    style ApiProxy fill:#f59e0b,color:#fff,stroke:#d97706
    style Express fill:#ef4444,color:#fff,stroke:#dc2626
