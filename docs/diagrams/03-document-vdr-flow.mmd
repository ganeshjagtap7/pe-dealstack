flowchart TD
    subgraph Entry["Document Entry Points"]
        direction LR
        Upload["Direct Upload
        POST /api/documents"]
        CIMIngest["CIM Ingest
        POST /api/ingest"]
        URLIngest["URL Ingest
        POST /api/ingest/url"]
        EmailIngest["Email Ingest
        POST /api/ingest/email"]
        ChatAttach["Chat Attachment
        deal-chat-attachments.js"]
    end

    Upload --> Validate
    CIMIngest --> Validate
    URLIngest --> Validate
    EmailIngest --> Validate
    ChatAttach --> Validate

    Validate["File Validation
    Magic bytes check
    100MB size limit
    fileValidator.ts"]

    Validate -->|Valid| Store["Store in Supabase Storage"]
    Validate -->|Invalid| Reject["Rejected — Error returned"]

    Store --> AIClassify["AI Classification
    documentParser.ts"]

    AIClassify --> DocType{Document Type}
    DocType -->|CIM| CIM["Confidential Info Memo"]
    DocType -->|Teaser| Teaser["Deal Teaser"]
    DocType -->|Financial| Financial["Financial Statements"]
    DocType -->|Legal| Legal["Legal Documents"]
    DocType -->|Tax| Tax["Tax Returns"]
    DocType -->|Other| Other["Other Documents"]

    Financial -->|Auto-trigger| FinExtract["Financial Extraction
    LangGraph 5-Node Agent
    Azure → PDF text → Vision"]

    Store --> Index["Document Indexed
    DocumentChunk table
    Available for RAG Chat"]

    subgraph VDR["Virtual Data Room — React App (vdr.tsx)"]
        direction TB
        FolderTree["Folder Tree
        Hierarchical navigation
        Drag & drop"]
        SmartFilters["Smart Filters
        4 built-in: PDFs, Spreadsheets,
        AI Warnings, Last 30 Days
        + 7 custom presets"]
        FileTable["File Table
        Sort, select, bulk actions"]
        Search["Cross-Folder Search
        Searches ALL folders
        Blue banner with count"]
        InsightsPanel["AI Insights Panel
        Completion %, red flags,
        missing documents"]
        ConfirmDialog["Confirm Dialog
        danger / warning / info"]
        Toast["Toast Notifications
        success / error / warning / info"]
    end

    subgraph DefaultFolders["Default VDR Folders (auto-created)"]
        direction LR
        F1["100 Financials"]
        F2["200 Legal"]
        F3["300 Commercial"]
        F4["400 HR & Data"]
        F5["500 IP"]
    end

    subgraph DocActions["Document Actions"]
        direction LR
        Preview["Preview
        docPreview.js"]
        Download["Download"]
        Move["Move to Folder"]
        Share["Share Link
        documents-sharing.ts"]
        Tag["Tag & Highlight"]
        Delete["Delete"]
        RequestDoc["Request Document
        Resend email + in-app notification"]
    end

    CIM --> VDR
    Teaser --> VDR
    Financial --> VDR
    Legal --> VDR
    Tax --> VDR
    Other --> VDR

    VDR --> DocActions
    VDR --> DefaultFolders

    style Upload fill:#003366,color:#fff,stroke:#002855
    style CIMIngest fill:#003366,color:#fff,stroke:#002855
    style URLIngest fill:#003366,color:#fff,stroke:#002855
    style EmailIngest fill:#003366,color:#fff,stroke:#002855
    style ChatAttach fill:#003366,color:#fff,stroke:#002855
