    style FinExtract fill:#6366f1,color:#fff,stroke:#4f46e5
    style Reject fill:#ef4444,color:#fff,stroke:#dc2626
    style Store fill:#3b82f6,color:#fff,stroke:#2563eb
    style Index fill:#10b981,color:#fff,stroke:#059669
    style FolderTree fill:#10b981,color:#fff,stroke:#059669
    style SmartFilters fill:#10b981,color:#fff,stroke:#059669
