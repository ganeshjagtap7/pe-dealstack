{
  "name": "ai-crm",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:api": "npm run build --workspace=@ai-crm/api",
    "start:prod": "NODE_ENV=production node apps/api/dist/index.js",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "dev:api": "npm run dev --workspace=@ai-crm/api",
    "dev:next": "npm run dev --workspace=@ai-crm/web-next"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "@langchain/anthropic": "^1.3.25",
    "cyndra-agent": "^1.2.63"
  }
}
